{
  "$schema": "https://json-schema.org/draft-07/schema",
  "type": "object",
  "properties": {
    "global": {
      "type": "object",
      "properties": {
        "imagePullPolicy": {"type": "string"}
      }
    },
    "controlPlane": {
      "type": "object",
      "properties": {
        "enabled": {"type": "boolean"},
        "image": {"type": "string"},
        "replicas": {"type": "integer", "minimum": 1}
      }
    },
    "agent": {
      "type": "object",
      "properties": {
        "enabled": {"type": "boolean"},
        "image": {"type": "string"},
        "controlPlaneUrl": {"type": "string"},
        "secret": {
          "type": "object",
          "properties": {
            "existingSecretName": {"type": "string"},
            "bootstrapToken": {"type": "string"}
          }
        }
      }
    }
  }
}
